# ─────────────────────────────────────────────────────────────────────────────
# youtube-studio — environment variables
# Copy this file to `.env` and fill in the values. `.env` is gitignored (secrets
# never get committed). On a fresh machine, copy the real values from your other
# machine's .env, or from the GitHub repo Secrets (Settings → Secrets → Actions).
# ─────────────────────────────────────────────────────────────────────────────

# == REQUIRED: script generation (pick one provider via SCRIPT_PROVIDER) ========
# "claude" uses the Claude Code CLI (your Max subscription — run `claude` to log in,
# no key needed locally). "gemini" uses the free Gemini HTTP API (needs GEMINI_API_KEY).
SCRIPT_PROVIDER=claude
GEMINI_API_KEY=                 # free key from https://aistudio.google.com/apikey
                                # also powers image-gen (thumbnails, storyboard) + vision

# == REQUIRED: free stock footage (the default visual source) ===================
PEXELS_API_KEY=                 # https://www.pexels.com/api/
PIXABAY_API_KEY=                # https://pixabay.com/api/docs/

# == REQUIRED to publish: YouTube Data API OAuth =================================
# One-time: create an OAuth client (Desktop) in Google Cloud Console, then run
#   npm run mint-token       # opens a browser, prints YT_REFRESH_TOKEN
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# == OPTIONAL: notifications ====================================================
DISCORD_WEBHOOK=                # start/finish/failure pings

# == OPTIONAL: premium voice (edge-tts is the free default; no key needed) =======
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# == OPTIONAL: other image providers ============================================
CLOUDFLARE_ACCOUNT_ID=          # Cloudflare Workers AI image gen (IMAGE_PROVIDER=cf)
CLOUDFLARE_API_TOKEN=
HF_TOKEN=                       # Hugging Face (some experimental providers)
MESHY_API_KEY=                  # 3D model gen (kids-studio experiment only)

# == LOCAL IMAGE GEN via ComfyUI (optional; runs on Windows/Linux/Mac) ==========
# The powerful-machine path. Point these at your local ComfyUI install.
COMFY_SERVER=127.0.0.1:8188
# COMFY_DIR: where ComfyUI is cloned.  Windows example: C:\Users\you\ComfyUI
COMFY_DIR=/Users/ehtisham/ComfyUI
# COMFY_PY: the venv python.  Linux/Mac: $COMFY_DIR/venv/bin/python
#           Windows:                     %COMFY_DIR%\venv\Scripts\python.exe
COMFY_PY=/Users/ehtisham/ComfyUI/venv/bin/python
COMFY_CKPT=RealVisXL_V5.0_fp16.safetensors
COMFY_LORA=Hyper-SDXL-8steps-CFG-lora.safetensors

# == LOCAL VIDEO GEN via Draw Things (macOS ONLY — see README for Windows) =======
# wan.ts drives the Draw Things HTTP API. On Windows use ComfyUI + Wan instead.
DT_API=http://127.0.0.1:7860
WAN_W=960
WAN_H=544
WAN_STEPS=28                    # 28 is the quality floor; 20 undercooks/smears
WAN_BEAT_WORDS=7
WAN_WORDS=140
# WAN_NICHE, WAN_STYLE, WAN_NEG — optional prompt overrides (see gen-wan-script.ts)

# == TUNING KNOBS (all optional; sensible defaults in code) ======================
# Long video:  VIDEO_WORDS(850) VIDEO_SCENES(8) BEAT_WORDS(12) CAPTION_WORDS(4)
# Publishing:  PUBLISH_MODE(approval|auto)  NO_PUBLISH(1 to skip upload)
# Orientation: ORIENT(landscape|portrait)   VOICE_PROVIDER(edge|elevenlabs)
# Image src:   IMAGE_PROVIDER(gemini|comfy|cf|pollinations|...)
