{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InfotainmentStu Studio",
  "version": "0.1.0",
  "identifier": "co.devhouse.infotainmentstu",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "InfotainmentStu Studio",
        "width": 920,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns"]
  }
}
